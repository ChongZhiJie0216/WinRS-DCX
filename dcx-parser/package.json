{
  "name": "dcx-parser",
  "description": "Protocol parser and serializer for Behringer DCX2496 DSP device",
  "version": "0.0.1",
  "author": "Lasse Lukkari <lasse.lukkari@gmail.com>",
  "repository": "github:lasselukkari/dcx-ui",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@vitest/eslint-plugin": "^1.6.6",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "xo": "^1.2.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "xo",
    "lint:fix": "xo --fix"
  },
  "xo": {
    "space": true,
    "prettier": true,
    "rules": {
      "@typescript-eslint/naming-convention": "off",
      "no-bitwise": "off"
    }
  },
  "dependencies": {
    "@types/serialport": "^8.0.5",
    "serialport": "^13.0.0"
  }
}